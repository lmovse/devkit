{
    "mcpServers": {
        "chrome-devtools": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "chrome-devtools-mcp@latest"
            ],
            "env": {}
        },
        "MiniMax": {
            "type": "stdio",
            "command": "uvx",
            "args": [
                "minimax-coding-plan-mcp",
                "-y"
            ],
            "env": {
                "MINIMAX_API_KEY": "xxx",
                "MINIMAX_API_HOST": "https://api.minimaxi.com"
            }
        }
    }
}